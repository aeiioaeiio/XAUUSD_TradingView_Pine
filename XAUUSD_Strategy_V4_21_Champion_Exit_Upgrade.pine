alertcondition(execLssScalp,     title="LSS SCALP",     message="XAUUSD V4.21 LSS SCALP SELL")
alertcondition(blockSellTrendFlip, title="NO SELL TREND FLIP", message="XAUUSD V4.21 blocked SELL because price reclaimed bullish structure")
alertcondition(breakoutRetestBuy, title="BREAKOUT RETEST BUY", message="XAUUSD V4.21 breakout retest BUY watch/confirm")
alertcondition(execBreakdownSell, title="BREAKDOWN SELL", message="XAUUSD V4.21 BREAKDOWN SELL")
alertcondition(extremeBuyWatch, title="EXTREME BUY WATCH", message="XAUUSD V4.21 EXTREME BUY WATCH - wait for reversal confirmation")
alertcondition(canPyramidLong, title="BUY ADD", message="XAUUSD V4.21 SAFE PYRAMID BUY ADD")
alertcondition(canPyramidShort, title="SELL ADD", message="XAUUSD V4.21 SAFE PYRAMID SELL ADD")