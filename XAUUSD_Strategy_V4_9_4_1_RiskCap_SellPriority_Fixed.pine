//@version=5
strategy("XAUUSD Strategy V4.9.4 - Risk Cap + Sell Priority", overlay=true, max_lines_count=500, max_labels_count=500, initial_capital=1000, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.cash_per_order, commission_value=0)

//═══════════════════════════════════════
// SETTINGS
//═══════════════════════════════════════
stochLen   = input.int(5,  "Stoch Period", group="Core")
stochKLen  = input.int(3,  "Stoch K",      group="Core")
stochDLen  = input.int(3,  "Stoch D",      group="Core")
rsiLen     = input.int(14, "RSI Period",   group="Core")
emaFastLen = input.int(20, "EMA Fast",     group="Core")
emaSlowLen = input.int(50, "EMA Slow",     group="Core")
emaTrendLen= input.int(200,"EMA Trend",    group="Core")
atrLen     = input.int(14, "ATR Period",   group="Risk")

mode = input.string("Confirm Only", "Backtest Mode", options=["Confirm Only", "Confirm + Scalp", "Scalp Only", "Sell Only", "Buy Only"], group="Backtest")
useConfirmedBar = input.bool(true, "Use Closed Bar Only", group="Backtest")

// V4.9.4: keep V4.9.4 profit core, then cap large-loss trades and tighten BUY quality.
enableBuyConfirm  = input.bool(true,  "Enable BUY CONFIRM",  group="V4.9.4 Signal Legs")
enableSellConfirm = input.bool(true,  "Enable SELL CONFIRM", group="V4.9.4 Signal Legs")
enableLsbScalp    = input.bool(false, "Enable LSB SCALP",    group="V4.9.4 Signal Legs")
enableLssScalp    = input.bool(false, "Enable LSS SCALP",    group="V4.9.4 Signal Legs")
showDisabledLegs  = input.bool(false, "Show Disabled Scalp Marks for Review", group="V4.9.4 Signal Legs")

sellOb      = input.float(70, "M15 Sell OB Level", group="M15 Trigger")
buyOs       = input.float(30, "M15 Buy OS Level",  group="M15 Trigger")
wickPct     = input.float(0.35, "M15 Rejection Wick %", group="M15 Trigger", step=0.05)
requireM15  = input.bool(true, "Require M15 Trigger for Confirm", group="M15 Trigger")

fibLookback = input.int(50, "Fib Lookback", group="Zone")
fibTolAtr   = input.float(0.45, "Fib/EMA Zone Tolerance x ATR", group="Zone", step=0.05)
noChaseAtr  = input.float(1.35, "No Chase Distance from EMA20 x ATR", group="Zone", step=0.05)

rrConfirm   = input.float(1.5, "Confirm TP RR", group="Risk", step=0.1)
rrScalp     = input.float(0.8, "Scalp TP RR", group="Risk", step=0.1)
slAtrBuf    = input.float(0.35, "Confirm SL Buffer x ATR", group="Risk", step=0.05)
scalpSlAtr  = input.float(0.12, "Scalp SL Buffer x ATR", group="Risk", step=0.02)
swingLb     = input.int(8, "Confirm SL Swing Lookback", group="Risk", minval=2)
scalpLb     = input.int(3, "Scalp SL Swing Lookback", group="Risk", minval=1)

showDash    = input.bool(true, "Show Dashboard", group="Display")
showSignals = input.bool(true, "Show Signals", group="Display")
showWatch   = input.bool(true, "Show Watch Marks", group="Display")
showFib     = input.bool(true, "Show Key Fib", group="Display")

// V4.9.4 Risk Cap / Trade Management
useRiskCap  = input.bool(true, "Use Max SL / Risk Cap", group="V4.9.4 Risk Cap")
riskCapMode = input.string("Cap SL", "Risk Cap Mode", options=["Cap SL", "Block Trade"], group="V4.9.4 Risk Cap")
maxSlPoints = input.float(60.0, "Max SL Distance (price points)", group="V4.9.4 Risk Cap", step=1.0)

// Optional session filter. Default off to keep V4.9.3 trade frequency.
useSessionFilter = input.bool(false, "Use Session Filter", group="Session")
tradeSession     = input.session("1300-0100", "Trading Session", group="Session")

// BUY quality filters. These reduce large BUY losses from the V4.9.3 test.
useStrictBuy      = input.bool(true, "Use Strict BUY Quality", group="BUY Quality")
buyRsiMin         = input.float(45.0, "BUY Min H1 RSI", group="BUY Quality", step=0.5)
requireBuyEma20   = input.bool(true, "BUY Require Close > EMA20", group="BUY Quality")
blockBuyH4Bear    = input.bool(true, "Block BUY when H4 Bear", group="BUY Quality")
blockBuyDeepBear  = input.bool(true, "Block BUY under EMA200 + H1 Bear", group="BUY Quality")

// SELL priority filters. SELL was the strongest profit leg in V4.9.3.
useSellPriority = input.bool(true, "Use SELL Priority Quality", group="SELL Quality")
sellRsiMax      = input.float(62.0, "SELL Max H1 RSI", group="SELL Quality", step=0.5)

//═══════════════════════════════════════
// HELPER FUNCTIONS
//═══════════════════════════════════════
f_k() => ta.sma(ta.stoch(close, high, low, stochLen), stochKLen)
f_d() => ta.sma(f_k(), stochDLen)
f_rng() => math.max(high - low, syminfo.mintick)
f_upper() => high - math.max(open, close)
f_lower() => math.min(open, close) - low

//═══════════════════════════════════════
// BASE / MTF DATA
//═══════════════════════════════════════
ema20  = ta.ema(close, emaFastLen)
ema50  = ta.ema(close, emaSlowLen)
ema200 = ta.ema(close, emaTrendLen)
atr    = ta.atr(atrLen)
rsi    = ta.rsi(close, rsiLen)
k      = f_k()
d      = f_d()

h4K = request.security(syminfo.tickerid, "240", f_k(), barmerge.gaps_off, barmerge.lookahead_off)
h4D = request.security(syminfo.tickerid, "240", f_d(), barmerge.gaps_off, barmerge.lookahead_off)
h4Close = request.security(syminfo.tickerid, "240", close, barmerge.gaps_off, barmerge.lookahead_off)
h4Ema50 = request.security(syminfo.tickerid, "240", ta.ema(close, emaSlowLen), barmerge.gaps_off, barmerge.lookahead_off)

m15O = request.security(syminfo.tickerid, "15", open,  barmerge.gaps_off, barmerge.lookahead_off)
m15H = request.security(syminfo.tickerid, "15", high,  barmerge.gaps_off, barmerge.lookahead_off)
m15L = request.security(syminfo.tickerid, "15", low,   barmerge.gaps_off, barmerge.lookahead_off)
m15C = request.security(syminfo.tickerid, "15", close, barmerge.gaps_off, barmerge.lookahead_off)
m15K = request.security(syminfo.tickerid, "15", f_k(), barmerge.gaps_off, barmerge.lookahead_off)
m15D = request.security(syminfo.tickerid, "15", f_d(), barmerge.gaps_off, barmerge.lookahead_off)
m15Rsi = request.security(syminfo.tickerid, "15", ta.rsi(close, rsiLen), barmerge.gaps_off, barmerge.lookahead_off)
m15Rng = request.security(syminfo.tickerid, "15", f_rng(), barmerge.gaps_off, barmerge.lookahead_off)
m15Upper = request.security(syminfo.tickerid, "15", f_upper(), barmerge.gaps_off, barmerge.lookahead_off)
m15Lower = request.security(syminfo.tickerid, "15", f_lower(), barmerge.gaps_off, barmerge.lookahead_off)

confirmed = useConfirmedBar ? barstate.isconfirmed : true
sessionActive = not useSessionFilter or not na(time(timeframe.period, tradeSession))

//═══════════════════════════════════════
// TREND / ZONE
//═══════════════════════════════════════
h1Bear = close < ema50 and ema20 < ema50 and close < ema200
h1Bull = close > ema50 and ema20 > ema50
h4Bear = h4Close < h4Ema50 or (h4K > 50 and h4K < h4D)
h4Bull = h4Close > h4Ema50 or (h4K < 50 and h4K > h4D)

swingHigh = ta.highest(high, fibLookback)
swingLow  = ta.lowest(low, fibLookback)
fibRange  = math.max(swingHigh - swingLow, syminfo.mintick)
fib618    = swingHigh - fibRange * 0.618
fib786    = swingHigh - fibRange * 0.786
fib382    = swingHigh - fibRange * 0.382
fib500    = swingHigh - fibRange * 0.500
zoneTol   = atr * fibTolAtr

nearSellZone = math.abs(close - ema20) <= zoneTol or math.abs(close - ema50) <= zoneTol or math.abs(close - fib382) <= zoneTol or math.abs(close - fib500) <= zoneTol or math.abs(close - fib618) <= zoneTol
nearBuyZone  = math.abs(close - ema20) <= zoneTol or math.abs(close - fib618) <= zoneTol or math.abs(close - fib786) <= zoneTol or low <= ta.lowest(low, 10)[1] + zoneTol

chaseSell = close < ema20 - atr * noChaseAtr
chaseBuy  = close > ema20 + atr * noChaseAtr

//═══════════════════════════════════════
// CANDLE / TRIGGER
//═══════════════════════════════════════
barRng = math.max(high - low, syminfo.mintick)
upperW = high - math.max(open, close)
lowerW = math.min(open, close) - low
bearReject = upperW / barRng >= 0.35 and close < open
bullReject = lowerW / barRng >= 0.35 and close > open

m15BearReject = m15Upper / m15Rng >= wickPct and m15C < m15O
m15BullReject = m15Lower / m15Rng >= wickPct and m15C > m15O
m15HookDown   = m15K < m15D and m15K < m15K[1]
m15HookUp     = m15K > m15D and m15K > m15K[1]
m15SellTrig   = (m15K >= sellOb or m15K[1] >= sellOb) and (m15HookDown or m15BearReject or m15C < m15O and m15C < m15C[1])
m15BuyTrig    = (m15K <= buyOs or m15K[1] <= buyOs) and (m15HookUp or m15BullReject or m15C > m15O and m15C > m15C[1])

// Liquidity sweep scalp
lsb = low < ta.lowest(low, 5)[1] and close > low and lowerW / barRng >= 0.45
lss = high > ta.highest(high, 5)[1] and close < high and upperW / barRng >= 0.45

//═══════════════════════════════════════
// PROFESSIONAL STATE MODEL
//═══════════════════════════════════════
watchSell = confirmed and h1Bear and nearSellZone and not chaseSell and (m15K > sellOb or bearReject or m15BearReject)
watchBuy  = confirmed and (h1Bull or lsb) and nearBuyZone and not chaseBuy and (m15K < buyOs or bullReject or m15BullReject or lsb)

// V4.9.4 Quality filters
buyQuality = not useStrictBuy or ((rsi >= buyRsiMin) and (not requireBuyEma20 or close > ema20) and (not blockBuyH4Bear or not h4Bear) and (not blockBuyDeepBear or not (close < ema200 and h1Bear)))
sellQuality = not useSellPriority or (rsi <= sellRsiMax and (h4Bear or not h4Bull))

sellConfirm = confirmed and sessionActive and h1Bear and nearSellZone and not chaseSell and (not requireM15 or m15SellTrig) and sellQuality
buyConfirm  = confirmed and sessionActive and h1Bull and nearBuyZone and not chaseBuy  and (not requireM15 or m15BuyTrig)  and (h4Bull or not h4Bear) and buyQuality

lsbScalp = confirmed and sessionActive and lsb and not chaseBuy and (m15HookUp or m15BullReject or m15K > m15D)
lssScalp = confirmed and sessionActive and lss and not chaseSell and (m15HookDown or m15BearReject or m15K < m15D)

// Executable signals after leg filter. Default disables scalp legs because V4.9 test showed they reduce total PnL.
execBuyConfirm  = buyConfirm and enableBuyConfirm
execSellConfirm = sellConfirm and enableSellConfirm
execLsbScalp    = lsbScalp and enableLsbScalp
execLssScalp    = lssScalp and enableLssScalp

noTrade = confirmed and ((chaseSell and h1Bear) or (chaseBuy and h1Bull) or (not watchSell and not watchBuy and not sellConfirm and not buyConfirm and not lsbScalp and not lssScalp))

state = execSellConfirm ? "SELL CONFIRM" : execBuyConfirm ? "BUY CONFIRM" : execLsbScalp ? "LSB SCALP" : execLssScalp ? "LSS SCALP" : watchSell ? "WATCH SELL" : watchBuy ? "WATCH BUY" : noTrade ? "NO TRADE" : "WAIT"
stateColor = execSellConfirm or execLssScalp or watchSell ? color.red : execBuyConfirm or execLsbScalp or watchBuy ? color.lime : noTrade ? color.gray : color.yellow

//═══════════════════════════════════════
// SL / TP
//═══════════════════════════════════════
slBuyRaw  = ta.lowest(low, swingLb) - atr * slAtrBuf
slSellRaw = ta.highest(high, swingLb) + atr * slAtrBuf
riskBuyRaw = math.max(close - slBuyRaw, syminfo.mintick)
riskSellRaw = math.max(slSellRaw - close, syminfo.mintick)

riskBuyAllowed  = not useRiskCap or riskCapMode == "Cap SL" or riskBuyRaw <= maxSlPoints
riskSellAllowed = not useRiskCap or riskCapMode == "Cap SL" or riskSellRaw <= maxSlPoints

slBuyConfirm  = useRiskCap and riskCapMode == "Cap SL" ? math.max(slBuyRaw, close - maxSlPoints) : slBuyRaw
slSellConfirm = useRiskCap and riskCapMode == "Cap SL" ? math.min(slSellRaw, close + maxSlPoints) : slSellRaw
riskBuyConfirm = math.max(close - slBuyConfirm, syminfo.mintick)
riskSellConfirm = math.max(slSellConfirm - close, syminfo.mintick)
tpBuyConfirm = close + riskBuyConfirm * rrConfirm
tpSellConfirm = close - riskSellConfirm * rrConfirm

slLsb = ta.lowest(low, scalpLb) - atr * scalpSlAtr
slLss = ta.highest(high, scalpLb) + atr * scalpSlAtr
riskLsb = math.max(close - slLsb, syminfo.mintick)
riskLss = math.max(slLss - close, syminfo.mintick)
tpLsb = close + riskLsb * rrScalp
tpLss = close - riskLss * rrScalp

canLongConfirm  = (mode == "Confirm Only" or mode == "Confirm + Scalp" or mode == "Buy Only") and enableBuyConfirm
canShortConfirm = (mode == "Confirm Only" or mode == "Confirm + Scalp" or mode == "Sell Only") and enableSellConfirm
canScalp = mode == "Confirm + Scalp" or mode == "Scalp Only"
canLsbScalp = canScalp and enableLsbScalp
canLssScalp = canScalp and enableLssScalp

//═══════════════════════════════════════
// STRATEGY ORDERS
//═══════════════════════════════════════
if execBuyConfirm and canLongConfirm and riskBuyAllowed and strategy.position_size == 0
    strategy.entry("BUY CONFIRM", strategy.long)
    strategy.exit("BUY EXIT", "BUY CONFIRM", stop=slBuyConfirm, limit=tpBuyConfirm)

if execSellConfirm and canShortConfirm and riskSellAllowed and strategy.position_size == 0
    strategy.entry("SELL CONFIRM", strategy.short)
    strategy.exit("SELL EXIT", "SELL CONFIRM", stop=slSellConfirm, limit=tpSellConfirm)

if execLsbScalp and canLsbScalp and strategy.position_size == 0
    strategy.entry("LSB SCALP", strategy.long)
    strategy.exit("LSB EXIT", "LSB SCALP", stop=slLsb, limit=tpLsb)

if execLssScalp and canLssScalp and strategy.position_size == 0
    strategy.entry("LSS SCALP", strategy.short)
    strategy.exit("LSS EXIT", "LSS SCALP", stop=slLss, limit=tpLss)

//═══════════════════════════════════════
// DISPLAY
//═══════════════════════════════════════
plot(ema20,  "EMA20",  color=color.yellow, linewidth=1)
plot(ema50,  "EMA50",  color=color.orange, linewidth=2)
plot(ema200, "EMA200", color=color.white, linewidth=2)
plot(showFib ? fib618 : na, "Fib 0.618", color=color.new(color.orange, 35), linewidth=1)
plot(showFib ? fib786 : na, "Fib 0.786", color=color.new(color.red, 45), linewidth=1)

plotshape(showSignals and execBuyConfirm,  title="BUY CONFIRM",  text="BUY",  style=shape.triangleup,   location=location.belowbar, color=color.lime, textcolor=color.white, size=size.normal)
plotshape(showSignals and execSellConfirm, title="SELL CONFIRM", text="SELL", style=shape.triangledown, location=location.abovebar, color=color.red,  textcolor=color.white, size=size.normal)
plotshape(showSignals and execLsbScalp,    title="LSB SCALP",    text="LSB",  style=shape.diamond,      location=location.belowbar, color=color.aqua, textcolor=color.white, size=size.tiny)
plotshape(showSignals and execLssScalp,    title="LSS SCALP",    text="LSS",  style=shape.diamond,      location=location.abovebar, color=color.fuchsia, textcolor=color.white, size=size.tiny)
plotshape(showWatch and watchBuy and not execBuyConfirm and not execLsbScalp,   title="WATCH BUY",  text="BUY?",  style=shape.circle, location=location.belowbar, color=color.new(color.lime, 45), textcolor=color.white, size=size.tiny)
plotshape(showWatch and watchSell and not execSellConfirm and not execLssScalp, title="WATCH SELL", text="SELL?", style=shape.circle, location=location.abovebar, color=color.new(color.red, 45), textcolor=color.white, size=size.tiny)
plotshape(showDisabledLegs and lsbScalp and not enableLsbScalp, title="DISABLED LSB", text="xLSB", style=shape.xcross, location=location.belowbar, color=color.new(color.aqua, 20), textcolor=color.white, size=size.tiny)
plotshape(showDisabledLegs and lssScalp and not enableLssScalp, title="DISABLED LSS", text="xLSS", style=shape.xcross, location=location.abovebar, color=color.new(color.fuchsia, 20), textcolor=color.white, size=size.tiny)

var table dash = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 15), border_width=1)
if showDash and barstate.islast
    table.cell(dash, 0, 0, "XAU V4.9.4", text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(dash, 1, 0, state, text_color=stateColor, bgcolor=color.navy, text_size=size.small)
    table.cell(dash, 0, 1, "Trend", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, (h1Bear ? "H1 Bear" : h1Bull ? "H1 Bull" : "H1 Mid") + " | " + (h4Bear ? "H4 Bear" : h4Bull ? "H4 Bull" : "H4 Wait"), text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 2, "M15", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, "K:" + str.tostring(math.round(m15K,1)) + " D:" + str.tostring(math.round(m15D,1)), text_color=m15K > m15D ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 3, "Zone", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, nearSellZone ? "Sell Zone" : nearBuyZone ? "Buy Zone" : "Middle", text_color=nearSellZone ? color.red : nearBuyZone ? color.lime : color.gray, text_size=size.small)
    table.cell(dash, 0, 4, "Filter", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, chaseSell ? "No Chase Sell" : chaseBuy ? "No Chase Buy" : "OK", text_color=(chaseSell or chaseBuy) ? color.gray : color.lime, text_size=size.small)
    table.cell(dash, 0, 5, "Risk", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, execSellConfirm ? "S:" + str.tostring(math.round(riskSellConfirm,2)) + (riskSellAllowed ? " OK" : " BLOCK") : execBuyConfirm ? "B:" + str.tostring(math.round(riskBuyConfirm,2)) + (riskBuyAllowed ? " OK" : " BLOCK") : "Max:" + str.tostring(maxSlPoints), text_color=(riskBuyAllowed and riskSellAllowed) ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 6, "SL/TP", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, execSellConfirm ? str.tostring(math.round(slSellConfirm,2)) + "/" + str.tostring(math.round(tpSellConfirm,2)) : execBuyConfirm ? str.tostring(math.round(slBuyConfirm,2)) + "/" + str.tostring(math.round(tpBuyConfirm,2)) : execLsbScalp ? str.tostring(math.round(slLsb,2)) + "/" + str.tostring(math.round(tpLsb,2)) : execLssScalp ? str.tostring(math.round(slLss,2)) + "/" + str.tostring(math.round(tpLss,2)) : "-/-", text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 7, "Legs", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 7, (enableBuyConfirm?"B":"-") + "/" + (enableSellConfirm?"S":"-") + "/" + (enableLsbScalp?"LSB":"-") + "/" + (enableLssScalp?"LSS":"-"), text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 8, "Mode", text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(dash, 1, 8, mode, text_color=color.white, bgcolor=color.navy, text_size=size.small)

//═══════════════════════════════════════
// ALERTS
//═══════════════════════════════════════
alertcondition(watchBuy,     title="WATCH BUY",     message="XAUUSD V4.9.4 WATCH BUY")
alertcondition(watchSell,    title="WATCH SELL",    message="XAUUSD V4.9.4 WATCH SELL")
alertcondition(execBuyConfirm,   title="BUY CONFIRM",   message="XAUUSD V4.9.4 BUY CONFIRM")
alertcondition(execSellConfirm,  title="SELL CONFIRM",  message="XAUUSD V4.9.4 SELL CONFIRM")
alertcondition(execLsbScalp,     title="LSB SCALP",     message="XAUUSD V4.9.4 LSB SCALP BUY")
alertcondition(execLssScalp,     title="LSS SCALP",     message="XAUUSD V4.9.4 LSS SCALP SELL")
