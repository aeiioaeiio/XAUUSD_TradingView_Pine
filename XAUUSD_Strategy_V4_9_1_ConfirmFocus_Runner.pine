//@version=5
strategy("XAUUSD Strategy V4.9.1 - Confirm Focus + Runner", overlay=true, max_lines_count=500, max_labels_count=500,
     initial_capital=1000, default_qty_type=strategy.fixed, default_qty_value=0.01,
     commission_type=strategy.commission.cash_per_order, commission_value=0,
     pyramiding=2, process_orders_on_close=true)

//═══════════════════════════════════════
// V4.9.1 objective
// - Fix gaps from V4.9 backtest
// - Default = Confirm Only, scalp disabled
// - Add session filter, max-risk filter, stricter BUY, SELL priority
// - Add Partial + Runner exit to avoid exiting too early in trend
//═══════════════════════════════════════

//═══════════════════════════════════════
// SETTINGS
//═══════════════════════════════════════
stochLen    = input.int(5,  "Stoch Period", group="Core")
stochKLen   = input.int(3,  "Stoch K",      group="Core")
stochDLen   = input.int(3,  "Stoch D",      group="Core")
rsiLen      = input.int(14, "RSI Period",   group="Core")
emaFastLen  = input.int(20, "EMA Fast",     group="Core")
emaSlowLen  = input.int(50, "EMA Slow",     group="Core")
emaTrendLen = input.int(200,"EMA Trend",    group="Core")
atrLen      = input.int(14, "ATR Period",   group="Core")

mode = input.string("Confirm Only", "Backtest Mode", options=["Confirm Only", "Sell Only", "Buy Only", "Confirm + Scalp", "Scalp Only"], group="Backtest")
orderQty = input.float(0.01, "Order Qty / Lot", group="Backtest", step=0.01, minval=0.01)
useConfirmedBar = input.bool(true, "Use Closed Bar Only", group="Backtest")

useSessionFilter = input.bool(true, "Use Session Filter", group="Session")
tradeSession     = input.session("1400-2330", "Trade Session", group="Session")
sessionTz        = input.string("Asia/Bangkok", "Session Timezone", group="Session")

sellOb     = input.float(70, "M15 Sell OB Level", group="M15 Trigger")
buyOs      = input.float(30, "M15 Buy OS Level",  group="M15 Trigger")
wickPct    = input.float(0.35, "M15 Rejection Wick %", group="M15 Trigger", step=0.05)
requireM15 = input.bool(true, "Require M15 Trigger for Confirm", group="M15 Trigger")

fibLookback = input.int(50, "Fib Lookback", group="Zone")
fibTolAtr   = input.float(0.45, "Fib/EMA Zone Tolerance x ATR", group="Zone", step=0.05)
noChaseAtr  = input.float(1.20, "No Chase Distance from EMA20 x ATR", group="Zone", step=0.05)

// Backtest gap fix: BUY was weak, SELL was edge. Make BUY stricter by default.
strictBuyConfirm     = input.bool(true, "Strict BUY Confirm", group="Confirm Filters")
requireBuyH4Bull     = input.bool(true, "BUY requires H4 Bull / not H4 Bear", group="Confirm Filters")
requireBuyReclaimEma = input.bool(true, "BUY requires close above EMA20", group="Confirm Filters")
requireBuyRsiFloor   = input.bool(true, "BUY requires H1 RSI Floor", group="Confirm Filters")
buyRsiFloor          = input.float(45, "BUY RSI Floor", group="Confirm Filters")
preferSellWhenBear   = input.bool(true, "Prefer SELL when H1 Bear", group="Confirm Filters")

// Backtest gap fix: avoid very wide SL trades on small account.
useMaxRiskFilter = input.bool(true, "Use Max Risk Filter", group="Risk")
maxRiskPoints    = input.float(18.0, "Max SL Distance / Risk Points", group="Risk", step=0.5)
minRiskPoints    = input.float(2.0, "Min SL Distance / Risk Points", group="Risk", step=0.5)
slAtrBuf         = input.float(0.35, "Confirm SL Buffer x ATR", group="Risk", step=0.05)
swingLb          = input.int(8, "Confirm SL Swing Lookback", group="Risk", minval=2)

// Exit models
exitMode = input.string("Partial + Runner", "Exit Mode", options=["Fixed TP", "Partial + Runner", "ATR Trail"], group="Exit")
tp1RR    = input.float(1.0, "TP1 RR", group="Exit", step=0.1)
tp2RR    = input.float(1.8, "Fixed TP / TP2 RR", group="Exit", step=0.1)
runnerPct= input.float(50, "Runner Qty %", group="Exit", minval=10, maxval=90, step=5)
moveBEatRR = input.float(1.0, "Move Runner SL to BE after RR", group="Exit", step=0.1)
trailAtrMult = input.float(1.2, "Runner ATR Trail x", group="Exit", step=0.1)

// Keep scalp available for separate testing only, but disabled by default through mode.
rrScalp    = input.float(0.8, "Scalp TP RR", group="Scalp Test", step=0.1)
scalpSlAtr = input.float(0.12, "Scalp SL Buffer x ATR", group="Scalp Test", step=0.02)
scalpLb    = input.int(3, "Scalp SL Swing Lookback", group="Scalp Test", minval=1)

showDash    = input.bool(true, "Show Dashboard", group="Display")
showSignals = input.bool(true, "Show Confirm Signals", group="Display")
showWatch   = input.bool(true, "Show Watch Marks", group="Display")
showScalp   = input.bool(false, "Show Scalp Marks", group="Display")
showFib     = input.bool(true, "Show Key Fib", group="Display")

//═══════════════════════════════════════
// HELPER FUNCTIONS
//═══════════════════════════════════════
f_k() => ta.sma(ta.stoch(close, high, low, stochLen), stochKLen)
f_d() => ta.sma(f_k(), stochDLen)
f_rng() => math.max(high - low, syminfo.mintick)
f_upper() => high - math.max(open, close)
f_lower() => math.min(open, close) - low

//═══════════════════════════════════════
// BASE / MTF DATA
//═══════════════════════════════════════
ema20  = ta.ema(close, emaFastLen)
ema50  = ta.ema(close, emaSlowLen)
ema200 = ta.ema(close, emaTrendLen)
atr    = ta.atr(atrLen)
rsi    = ta.rsi(close, rsiLen)
k      = f_k()
d      = f_d()

h4K = request.security(syminfo.tickerid, "240", f_k(), barmerge.gaps_off, barmerge.lookahead_off)
h4D = request.security(syminfo.tickerid, "240", f_d(), barmerge.gaps_off, barmerge.lookahead_off)
h4Close = request.security(syminfo.tickerid, "240", close, barmerge.gaps_off, barmerge.lookahead_off)
h4Ema50 = request.security(syminfo.tickerid, "240", ta.ema(close, emaSlowLen), barmerge.gaps_off, barmerge.lookahead_off)

m15O = request.security(syminfo.tickerid, "15", open,  barmerge.gaps_off, barmerge.lookahead_off)
m15H = request.security(syminfo.tickerid, "15", high,  barmerge.gaps_off, barmerge.lookahead_off)
m15L = request.security(syminfo.tickerid, "15", low,   barmerge.gaps_off, barmerge.lookahead_off)
m15C = request.security(syminfo.tickerid, "15", close, barmerge.gaps_off, barmerge.lookahead_off)
m15K = request.security(syminfo.tickerid, "15", f_k(), barmerge.gaps_off, barmerge.lookahead_off)
m15D = request.security(syminfo.tickerid, "15", f_d(), barmerge.gaps_off, barmerge.lookahead_off)
m15Rng = request.security(syminfo.tickerid, "15", f_rng(), barmerge.gaps_off, barmerge.lookahead_off)
m15Upper = request.security(syminfo.tickerid, "15", f_upper(), barmerge.gaps_off, barmerge.lookahead_off)
m15Lower = request.security(syminfo.tickerid, "15", f_lower(), barmerge.gaps_off, barmerge.lookahead_off)

confirmed = useConfirmedBar ? barstate.isconfirmed : true
inSession = not useSessionFilter or not na(time(timeframe.period, tradeSession, sessionTz))

//═══════════════════════════════════════
// TREND / ZONE
//═══════════════════════════════════════
h1Bear = close < ema50 and ema20 < ema50 and close < ema200
h1Bull = close > ema50 and ema20 > ema50
h4Bear = h4Close < h4Ema50 or (h4K > 50 and h4K < h4D)
h4Bull = h4Close > h4Ema50 or (h4K < 50 and h4K > h4D)

swingHigh = ta.highest(high, fibLookback)
swingLow  = ta.lowest(low, fibLookback)
fibRange  = math.max(swingHigh - swingLow, syminfo.mintick)
fib382    = swingHigh - fibRange * 0.382
fib500    = swingHigh - fibRange * 0.500
fib618    = swingHigh - fibRange * 0.618
fib786    = swingHigh - fibRange * 0.786
zoneTol   = atr * fibTolAtr

nearSellZone = math.abs(close - ema20) <= zoneTol or math.abs(close - ema50) <= zoneTol or math.abs(close - fib382) <= zoneTol or math.abs(close - fib500) <= zoneTol or math.abs(close - fib618) <= zoneTol
nearBuyZone  = math.abs(close - ema20) <= zoneTol or math.abs(close - fib618) <= zoneTol or math.abs(close - fib786) <= zoneTol or low <= ta.lowest(low, 10)[1] + zoneTol

chaseSell = close < ema20 - atr * noChaseAtr
chaseBuy  = close > ema20 + atr * noChaseAtr

//═══════════════════════════════════════
// CANDLE / TRIGGER
//═══════════════════════════════════════
barRng = math.max(high - low, syminfo.mintick)
upperW = high - math.max(open, close)
lowerW = math.min(open, close) - low
bearReject = upperW / barRng >= 0.35 and close < open
bullReject = lowerW / barRng >= 0.35 and close > open

m15BearReject = m15Upper / m15Rng >= wickPct and m15C < m15O
m15BullReject = m15Lower / m15Rng >= wickPct and m15C > m15O
m15HookDown   = m15K < m15D and m15K < m15K[1]
m15HookUp     = m15K > m15D and m15K > m15K[1]
m15SellTrig   = (m15K >= sellOb or m15K[1] >= sellOb) and (m15HookDown or m15BearReject or (m15C < m15O and m15C < m15C[1]))
m15BuyTrig    = (m15K <= buyOs or m15K[1] <= buyOs) and (m15HookUp or m15BullReject or (m15C > m15O and m15C > m15C[1]))

lsb = low < ta.lowest(low, 5)[1] and close > low and lowerW / barRng >= 0.45
lss = high > ta.highest(high, 5)[1] and close < high and upperW / barRng >= 0.45

//═══════════════════════════════════════
// CONFIRM MODEL V4.9.1
//═══════════════════════════════════════
watchSell = confirmed and inSession and h1Bear and nearSellZone and not chaseSell and (m15K > sellOb or bearReject or m15BearReject)
watchBuy  = confirmed and inSession and (h1Bull or lsb) and nearBuyZone and not chaseBuy and (m15K < buyOs or bullReject or m15BullReject or lsb)

baseSellConfirm = confirmed and inSession and h1Bear and nearSellZone and not chaseSell and (not requireM15 or m15SellTrig) and (h4Bear or not h4Bull)
baseBuyConfirm  = confirmed and inSession and h1Bull and nearBuyZone and not chaseBuy and (not requireM15 or m15BuyTrig)

buyStrictOK = not strictBuyConfirm or ((not requireBuyH4Bull or h4Bull) and (not requireBuyReclaimEma or close > ema20) and (not requireBuyRsiFloor or rsi >= buyRsiFloor))

sellConfirmRaw = baseSellConfirm
buyConfirmRaw  = baseBuyConfirm and buyStrictOK

// SELL priority: if market is H1 Bear and both sides appear, do not let weak BUY trigger against trend.
sellConfirm = sellConfirmRaw and not (buyConfirmRaw and not h1Bear)
buyConfirm  = buyConfirmRaw and not (preferSellWhenBear and h1Bear)

// Scalp only if explicitly selected for testing.
lsbScalp = confirmed and inSession and lsb and not chaseBuy and (m15HookUp or m15BullReject or m15K > m15D)
lssScalp = confirmed and inSession and lss and not chaseSell and (m15HookDown or m15BearReject or m15K < m15D)

//═══════════════════════════════════════
// SL / TP / RISK FILTER
//═══════════════════════════════════════
slBuyConfirm  = ta.lowest(low, swingLb) - atr * slAtrBuf
slSellConfirm = ta.highest(high, swingLb) + atr * slAtrBuf
riskBuyConfirm = math.max(close - slBuyConfirm, syminfo.mintick)
riskSellConfirm = math.max(slSellConfirm - close, syminfo.mintick)

riskBuyOK  = not useMaxRiskFilter or (riskBuyConfirm <= maxRiskPoints and riskBuyConfirm >= minRiskPoints)
riskSellOK = not useMaxRiskFilter or (riskSellConfirm <= maxRiskPoints and riskSellConfirm >= minRiskPoints)

buyConfirmFinal  = buyConfirm and riskBuyOK
sellConfirmFinal = sellConfirm and riskSellOK

slLsb = ta.lowest(low, scalpLb) - atr * scalpSlAtr
slLss = ta.highest(high, scalpLb) + atr * scalpSlAtr
riskLsb = math.max(close - slLsb, syminfo.mintick)
riskLss = math.max(slLss - close, syminfo.mintick)
tpLsb = close + riskLsb * rrScalp
tpLss = close - riskLss * rrScalp

canLongConfirm  = mode == "Confirm Only" or mode == "Confirm + Scalp" or mode == "Buy Only"
canShortConfirm = mode == "Confirm Only" or mode == "Confirm + Scalp" or mode == "Sell Only"
canScalp = mode == "Confirm + Scalp" or mode == "Scalp Only"

//═══════════════════════════════════════
// STRATEGY ORDERS - CONFIRM FOCUS WITH RUNNER
//═══════════════════════════════════════
var float longEntry = na
var float longSL = na
var float longRisk = na
var float shortEntry = na
var float shortSL = na
var float shortRisk = na

newLong = buyConfirmFinal and canLongConfirm and strategy.position_size == 0
newShort = sellConfirmFinal and canShortConfirm and strategy.position_size == 0

if newLong
    longEntry := close
    longSL := slBuyConfirm
    longRisk := riskBuyConfirm
    if exitMode == "Partial + Runner"
        strategy.entry("BUY TP1", strategy.long, qty=orderQty * (100 - runnerPct) / 100)
        strategy.entry("BUY RUN", strategy.long, qty=orderQty * runnerPct / 100)
    else
        strategy.entry("BUY CONFIRM", strategy.long, qty=orderQty)

if newShort
    shortEntry := close
    shortSL := slSellConfirm
    shortRisk := riskSellConfirm
    if exitMode == "Partial + Runner"
        strategy.entry("SELL TP1", strategy.short, qty=orderQty * (100 - runnerPct) / 100)
        strategy.entry("SELL RUN", strategy.short, qty=orderQty * runnerPct / 100)
    else
        strategy.entry("SELL CONFIRM", strategy.short, qty=orderQty)

// Fixed TP exits
if exitMode == "Fixed TP"
    strategy.exit("BUY EXIT", "BUY CONFIRM", stop=longSL, limit=longEntry + longRisk * tp2RR)
    strategy.exit("SELL EXIT", "SELL CONFIRM", stop=shortSL, limit=shortEntry - shortRisk * tp2RR)

// Partial TP1 + runner exits. Runner stop moves to BE after TP1 RR and then trails with ATR.
if exitMode == "Partial + Runner"
    longTp1 = longEntry + longRisk * tp1RR
    shortTp1 = shortEntry - shortRisk * tp1RR
    longRunnerBaseStop = close >= longEntry + longRisk * moveBEatRR ? longEntry : longSL
    shortRunnerBaseStop = close <= shortEntry - shortRisk * moveBEatRR ? shortEntry : shortSL
    longRunnerStop = math.max(longRunnerBaseStop, close - atr * trailAtrMult)
    shortRunnerStop = math.min(shortRunnerBaseStop, close + atr * trailAtrMult)
    strategy.exit("BUY TP1 EXIT", "BUY TP1", stop=longSL, limit=longTp1)
    strategy.exit("BUY RUN EXIT", "BUY RUN", stop=longRunnerStop)
    strategy.exit("SELL TP1 EXIT", "SELL TP1", stop=shortSL, limit=shortTp1)
    strategy.exit("SELL RUN EXIT", "SELL RUN", stop=shortRunnerStop)

// ATR Trail mode = all position trails, no fixed target.
if exitMode == "ATR Trail"
    longTrailStop = math.max(longSL, close - atr * trailAtrMult)
    shortTrailStop = math.min(shortSL, close + atr * trailAtrMult)
    strategy.exit("BUY TRAIL EXIT", "BUY CONFIRM", stop=longTrailStop)
    strategy.exit("SELL TRAIL EXIT", "SELL CONFIRM", stop=shortTrailStop)

// Optional scalp for separate testing. Not included in default mode.
if lsbScalp and canScalp and strategy.position_size == 0
    strategy.entry("LSB SCALP", strategy.long, qty=orderQty)
    strategy.exit("LSB EXIT", "LSB SCALP", stop=slLsb, limit=tpLsb)

if lssScalp and canScalp and strategy.position_size == 0
    strategy.entry("LSS SCALP", strategy.short, qty=orderQty)
    strategy.exit("LSS EXIT", "LSS SCALP", stop=slLss, limit=tpLss)

//═══════════════════════════════════════
// STATE / DISPLAY
//═══════════════════════════════════════
noTrade = confirmed and (not inSession or (chaseSell and h1Bear) or (chaseBuy and h1Bull) or (not watchSell and not watchBuy and not sellConfirmFinal and not buyConfirmFinal and not lsbScalp and not lssScalp))
state = sellConfirmFinal ? "SELL CONFIRM" : buyConfirmFinal ? "BUY CONFIRM" : (canScalp and lsbScalp) ? "LSB SCALP" : (canScalp and lssScalp) ? "LSS SCALP" : watchSell ? "WATCH SELL" : watchBuy ? "WATCH BUY" : noTrade ? "NO TRADE" : "WAIT"
stateColor = sellConfirmFinal or watchSell or (canScalp and lssScalp) ? color.red : buyConfirmFinal or watchBuy or (canScalp and lsbScalp) ? color.lime : noTrade ? color.gray : color.yellow

plot(ema20,  "EMA20",  color=color.yellow, linewidth=1)
plot(ema50,  "EMA50",  color=color.orange, linewidth=2)
plot(ema200, "EMA200", color=color.white, linewidth=2)
plot(showFib ? fib618 : na, "Fib 0.618", color=color.new(color.orange, 35), linewidth=1)
plot(showFib ? fib786 : na, "Fib 0.786", color=color.new(color.red, 45), linewidth=1)

plotshape(showSignals and buyConfirmFinal,  title="BUY CONFIRM",  text="BUY",  style=shape.triangleup,   location=location.belowbar, color=color.lime, textcolor=color.white, size=size.normal)
plotshape(showSignals and sellConfirmFinal, title="SELL CONFIRM", text="SELL", style=shape.triangledown, location=location.abovebar, color=color.red,  textcolor=color.white, size=size.normal)
plotshape(showScalp and canScalp and lsbScalp, title="LSB SCALP", text="LSB", style=shape.diamond, location=location.belowbar, color=color.aqua, textcolor=color.white, size=size.tiny)
plotshape(showScalp and canScalp and lssScalp, title="LSS SCALP", text="LSS", style=shape.diamond, location=location.abovebar, color=color.fuchsia, textcolor=color.white, size=size.tiny)
plotshape(showWatch and watchBuy and not buyConfirmFinal, title="WATCH BUY", text="BUY?", style=shape.circle, location=location.belowbar, color=color.new(color.lime, 45), textcolor=color.white, size=size.tiny)
plotshape(showWatch and watchSell and not sellConfirmFinal, title="WATCH SELL", text="SELL?", style=shape.circle, location=location.abovebar, color=color.new(color.red, 45), textcolor=color.white, size=size.tiny)

var table dash = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 15), border_width=1)
if showDash and barstate.islast
    table.cell(dash, 0, 0, "XAU V4.9.1", text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(dash, 1, 0, state, text_color=stateColor, bgcolor=color.navy, text_size=size.small)
    table.cell(dash, 0, 1, "Trend", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 1, (h1Bear ? "H1 Bear" : h1Bull ? "H1 Bull" : "H1 Mid") + " | " + (h4Bear ? "H4 Bear" : h4Bull ? "H4 Bull" : "H4 Wait"), text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 2, "M15", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 2, "K:" + str.tostring(math.round(m15K,1)) + " D:" + str.tostring(math.round(m15D,1)), text_color=m15K > m15D ? color.lime : color.red, text_size=size.small)
    table.cell(dash, 0, 3, "Zone", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 3, nearSellZone ? "Sell Zone" : nearBuyZone ? "Buy Zone" : "Middle", text_color=nearSellZone ? color.red : nearBuyZone ? color.lime : color.gray, text_size=size.small)
    table.cell(dash, 0, 4, "Filter", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 4, not inSession ? "OUT SESSION" : chaseSell ? "No Chase Sell" : chaseBuy ? "No Chase Buy" : not riskBuyOK and buyConfirm ? "BUY Risk Wide" : not riskSellOK and sellConfirm ? "SELL Risk Wide" : "OK", text_color=(not inSession or chaseSell or chaseBuy) ? color.gray : color.lime, text_size=size.small)
    table.cell(dash, 0, 5, "Risk", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 5, sellConfirm ? str.tostring(math.round(riskSellConfirm,2)) : buyConfirm ? str.tostring(math.round(riskBuyConfirm,2)) : "-", text_color=color.white, text_size=size.small)
    table.cell(dash, 0, 6, "Exit", text_color=color.white, text_size=size.small)
    table.cell(dash, 1, 6, exitMode, text_color=color.yellow, text_size=size.small)
    table.cell(dash, 0, 7, "Mode", text_color=color.white, bgcolor=color.navy, text_size=size.small)
    table.cell(dash, 1, 7, mode, text_color=color.white, bgcolor=color.navy, text_size=size.small)

//═══════════════════════════════════════
// ALERTS
//═══════════════════════════════════════
alertcondition(watchBuy,          title="WATCH BUY",     message="XAUUSD V4.9.1 WATCH BUY")
alertcondition(watchSell,         title="WATCH SELL",    message="XAUUSD V4.9.1 WATCH SELL")
alertcondition(buyConfirmFinal,   title="BUY CONFIRM",   message="XAUUSD V4.9.1 BUY CONFIRM")
alertcondition(sellConfirmFinal,  title="SELL CONFIRM",  message="XAUUSD V4.9.1 SELL CONFIRM")
alertcondition(canScalp and lsbScalp, title="LSB SCALP", message="XAUUSD V4.9.1 LSB SCALP BUY")
alertcondition(canScalp and lssScalp, title="LSS SCALP", message="XAUUSD V4.9.1 LSS SCALP SELL")
